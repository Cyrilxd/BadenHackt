# ============================================================
# Internet EIN/AUS — Umgebungsvariablen
# Kopiere diese Datei als ".env" und passe die Werte an.
# ============================================================

# ── Backend ──────────────────────────────────────────────────

# JWT-Schlüssel: UNBEDINGT durch einen langen Zufallswert ersetzen!
# Beispiel: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_use_a_long_random_secret

# Authentifizierungsmodus: "ldap" | "local" | "auto"
# - ldap:  Nur LDAP (schlägt fehl wenn LDAP nicht erreichbar)
# - local: Nur lokale Benutzer aus der Datenbank
# - auto:  LDAP zuerst, Fallback auf lokale Benutzer
AUTH_MODE=ldap

# Datenbank (SQLite-Pfad innerhalb des Containers, nicht ändern)
DATABASE_URL=sqlite:////app/data/internet_control.db
DATABASE_PATH=/app/data/internet_control.db

# ── LDAP ─────────────────────────────────────────────────────

LDAP_HOST=ldap
LDAP_PORT=389
LDAP_BASE_DN=dc=hackathon,dc=local
LDAP_BIND_DN=cn=admin,dc=hackathon,dc=local

# LDAP Admin-Passwort: UNBEDINGT ändern!
LDAP_BIND_PASSWORD=CHANGE_ME_ldap_admin_password

LDAP_USER_SEARCH_BASE=ou=users,dc=hackathon,dc=local
LDAP_USER_SEARCH_FILTER=(uid={username})

# ── Firewall-Agent ────────────────────────────────────────────

# URL des Firewall-Agenten (intern im Docker-Netz)
FIREWALL_API_URL=http://shorewall-mock:8080

# Token für die Firewall-Agent API: UNBEDINGT ändern!
FIREWALL_API_TOKEN=CHANGE_ME_firewall_api_token

# Timeout in Sekunden für Firewall-API-Aufrufe
FIREWALL_API_TIMEOUT=5

# Firewall-Treiber: "mock" (Entwicklung) | "shorewall" (Produktion)
FIREWALL_DRIVER=mock

# ── Firewall-Agent (Shorewall-Pfade, nur bei FIREWALL_DRIVER=shorewall) ──

SHOREWALL_SOURCE_ZONE=loc
SHOREWALL_DEST_ZONE=net
SHOREWALL_RULES_FILE=/etc/shorewall/rules
SHOREWALL_MANAGED_RULES_FILE=/etc/shorewall/rules.d/badenhackt.rules

# ── Frontend ──────────────────────────────────────────────────

# API-Basis-URL für das Frontend (leer = relativ zum gleichen Host)
# Nur setzen wenn Frontend und Backend auf unterschiedlichen Hosts laufen.
VITE_API_URL=
